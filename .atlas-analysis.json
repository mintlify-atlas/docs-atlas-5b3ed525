  "keyFeatures": [
    "Block or manipulate requests based on IP ranges",
    "Predefined IP ranges for AI services (OpenAI, DeepSeek, GitHub Copilot)",
    "Multiple response strategies (block, custom, drop, garbage, redirect, tarpit, rate-limit)",
    "Support for custom CIDR ranges and whitelist functionality",
    "High-performance IP matching using Balanced ART routing table",
    "Integration with caddy-ratelimit for advanced rate limiting",
    "Docker support with pre-built images",
    "Extensible IP range fetchers for cloud providers"
  ],
  "publicApiSurface": [
    "defender <responder> - Main Caddyfile directive",
    "ranges - Configure IP ranges (CIDR or predefined keys)",
    "message - Custom response message (for 'custom' responder)",
    "status_code - HTTP status code (for 'custom' responder)",
    "url - Redirect URL (for 'redirect' responder)",
    "whitelist - Whitelist specific IPs from blocked ranges",
    "serve_ignore - Serve robots.txt with Disallow directive",
    "tarpit_config - Configuration for tarpit responder",
    "Responder types: block, custom, drop, garbage, redirect, ratelimit, tarpit",
    "Predefined ranges: aws, gcloud, azurepubliccloud, openai, deepseek, githubcopilot, mistral, vultr, cloudflare, digitalocean, linode, oci, aliyun, vpn, private, all",
    "Build-time ranges: tor, asn"
  ]
